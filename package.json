{
    "name": "cliuno",
    "version": "2.0.1",
    "description": "CLIuno is a CLI tool to make your journey in web development less painful (it makes your life way easier).",
    "keywords": [
        "all in one",
        "all-in-1",
        "all-in-one",
        "automation",
        "cli",
        "cliuno",
        "javascript",
        "nodeJs",
        "typescript"
    ],
    "homepage": "https://github.com/CLIuno/core#readme",
    "bugs": {
        "url": "https://github.com/CLIuno/core/issues"
    },
    "license": "MIT",
    "author": "ru44",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CLIuno/core.git"
    },
    "bin": {
        "cliuno": "dist/app.js"
    },
    "type": "module",
    "main": "dist/app.js",
    "module": "dist/app.js",
    "types": "dist/app.d.ts",
    "scripts": {
        "lint": "oxlint",
        "lintfix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "dev": "tsx ./src/app.ts",
        "build": "tsup",
        "release": "pnpm build && changeset publish",
        "prepare": "husky"
    },
    "dependencies": {
        "@inquirer/prompts": "^8.3.2",
        "chalk": "^5.6.2",
        "shelljs": "^0.10.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/node": "^25.5.0",
        "@types/shelljs": "^0.10.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "oxfmt": "^0.44.0",
        "oxlint": "^1.59.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    },
    "lint-staged": {
        "**/*.{js,ts}": [
            "pnpm lintfix"
        ]
    }
}
